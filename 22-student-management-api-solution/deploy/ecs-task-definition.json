{
  "family": "student-management-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::__AWS_ACCOUNT_ID__:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "student-api",
      "image": "public.ecr.aws/docker/library/busybox:1.36",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "QUARKUS_PROFILE",
          "value": "prod"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -sf http://localhost:8080/q/health/live || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 5,
        "startPeriod": 120
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/student-management-api",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
